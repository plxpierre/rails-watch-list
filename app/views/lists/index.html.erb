<div class="banner mb-5" style="background-image: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');">
  <div class="container text-center text-white">
    <h1 class="display-3 fw-bold">Save any kind of movies</h1>
    <p class="fs-4">Classic</p>
  </div>
</div>

<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">My Lists</h2>
    <%= link_to "Create a movie list", new_list_path, class: "btn btn-success rounded-pill px-4" %>
  </div>

  <div class="row">
    <% @lists.each do |list| %>
      <div class="col-12 col-sm-6 col-md-4 mb-4">
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <%# ÉTAPE 6 : On vérifie si une photo est attachée, sinon image par défaut %>
          <% if list.photo.attached? %>
            <% photo_url = cl_image_path(list.photo.key, height: 300, crop: :fill) %>
          <% else %>
            <% photo_url = 'https://images.unsplash.com/photo-1440404653325-ab127d49abc1?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80' %>
          <% end %>

          <div class="list-card rounded shadow-sm d-flex align-items-center justify-content-center"
               style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= photo_url %>');">
            <h3 class="text-white fw-bold m-0"><%= list.name %></h3>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
